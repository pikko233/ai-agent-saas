{
  "name": "ai-agent-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev:webhook": "ngrok http --url=thong-squabble-sizzling.ngrok-free.dev 3000",
    "dev:agent": "cd agent-worker && uv run uvicorn main:app --host 127.0.0.1 --port 8787 --reload",
    "stop:agent": "kill-port 8787",
    "restart:agent": "npm run stop:agent && npm run dev:agent",
    "dev:inngest": "npx inngest-cli@latest dev",
    "dev:all": "killall ngrok 2>/dev/null; concurrently \"npm run dev:webhook\" \"npm run restart:agent\" \"npm run dev\" \"npm run dev:inngest\""
  },
